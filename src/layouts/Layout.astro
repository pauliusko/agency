---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  lang?: string;
}

const { title, description = 'Digital marketing agency', lang = 'lt' } = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=Manrope:wght@400;500;600;700&family=Oswald:wght@400;500;600;700&family=Share+Tech+Mono&display=swap" rel="stylesheet" />
  </head>
  <body>
    <slot />

    <script>
      // ── Scroll Reveal ──
      if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              if (e.isIntersecting) {
                e.target.classList.add('visible');
              }
            });
          },
          { threshold: 0.12, rootMargin: '0px 0px -30px 0px' }
        );
        document.querySelectorAll('[data-animate]').forEach((el) => observer.observe(el));
      }

      // ── i18n ──
      const defaultLang = 'lt';

      async function loadTranslations(lang: string) {
        try {
          const mod = await import(`../i18n/${lang}.json`);
          const json = mod.default;
          function resolve(obj: any, path: string): any {
            return path.split('.').reduce((o, k) => o?.[k], obj);
          }
          document.documentElement.lang = lang === 'lt' ? 'lt' : lang === 'ru' ? 'ru' : 'en';
          document.documentElement.classList.remove('lang-lt', 'lang-en', 'lang-ru');
          document.documentElement.classList.add(`lang-${lang}`);

          document.querySelectorAll('[data-i18n]').forEach((el) => {
            const node = el as HTMLElement;
            const key = node.dataset.i18n!;
            const val = resolve(json, key);
            if (val === undefined || val === null) return;
            if (typeof val === 'string') {
              if (node.dataset.i18nBr === 'true') node.innerHTML = val.replace(/\n/g, '<br/>');
              else node.textContent = val;
            }
          });

          document.querySelectorAll('[data-i18n-placeholder]').forEach((el) => {
            const key = (el as HTMLInputElement).dataset.i18nPlaceholder!;
            const val = resolve(json, key);
            if (typeof val === 'string' && val) (el as HTMLInputElement).placeholder = val;
          });

          const sph = resolve(json, 'contact.servicePlaceholder');
          if (typeof sph === 'string') {
            const sel = document.getElementById('field-service') as HTMLSelectElement | null;
            if (sel?.options?.[0]) sel.options[0].textContent = sph;
          }

          document.querySelectorAll('[data-i18n-marquee]').forEach((el) => {
            const key = (el as HTMLElement).dataset.i18nMarquee!;
            const val = resolve(json, key);
            if (typeof val === 'string' && val) {
              const dup = val + val + val + val;
              el.querySelectorAll('[data-marquee-track]').forEach((track) => {
                track.innerHTML = `<span class="marquee__text">${dup}</span><span class="marquee__text" aria-hidden="true">${dup}</span>`;
              });
            }
          });

          const fq = json.faq?.items;
          if (Array.isArray(fq)) {
            document.querySelectorAll('.faq__item').forEach((node, i) => {
              const d = fq[i];
              if (!d) return;
              const qel = node.querySelector('.faq__q-text');
              const ael = node.querySelector('.faq__answer p');
              if (qel) qel.textContent = d.q;
              if (ael) ael.textContent = d.a;
            });
          }

          const steps = json.process?.steps;
          if (Array.isArray(steps)) {
            document.querySelectorAll('[data-process-step]').forEach((node) => {
              const i = parseInt((node as HTMLElement).dataset.processStep || '-1', 10);
              const s = steps[i];
              if (!s) return;
              const titleEl = node.querySelector('.process__card-title');
              const descEl = node.querySelector('.process__card-desc');
              if (titleEl) titleEl.textContent = s.title;
              if (descEl) descEl.textContent = s.desc;
            });
          }

          const titems = json.testimonials?.items;
          if (Array.isArray(titems)) {
            document.querySelectorAll('[data-testimonial]').forEach((node) => {
              const i = parseInt((node as HTMLElement).dataset.testimonial || '-1', 10);
              const row = titems[i];
              if (!row) return;
              const q = node.querySelector('[data-t-quote]');
              const a = node.querySelector('[data-t-author]');
              const m = node.querySelector('[data-t-meta]');
              if (q) q.textContent = row.quote;
              if (a) a.textContent = row.author;
              if (m) m.textContent = row.meta;
            });
          }

          window.dispatchEvent(new CustomEvent('gronk:locale', { detail: { lang, json } }));
        } catch { /* silent */ }
      }

      function setLang(lang: string) {
        localStorage.setItem('lang', lang);
        loadTranslations(lang);
        document.querySelectorAll('[data-lang-btn]').forEach((btn) => {
          btn.classList.toggle('active', (btn as HTMLElement).dataset.langBtn === lang);
        });
      }

      // Init
      const savedLang = localStorage.getItem('lang') || defaultLang;
      if (savedLang !== defaultLang) document.documentElement.classList.add(`lang-${savedLang}`);

      document.querySelectorAll('[data-lang-btn]').forEach((btn) => {
        btn.classList.toggle('active', (btn as HTMLElement).dataset.langBtn === savedLang);
        btn.addEventListener('click', () => setLang((btn as HTMLElement).dataset.langBtn!));
      });
      loadTranslations(savedLang);
    </script>
  </body>
</html>

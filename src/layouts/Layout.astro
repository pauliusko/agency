---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  lang?: string;
}

const { title, description = 'Digital marketing agency', lang = 'lt' } = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=Share+Tech+Mono&display=swap" rel="stylesheet" />
  </head>
  <body>
    <slot />

    <script>
      // ── Scroll Reveal ──
      if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              if (e.isIntersecting) {
                e.target.classList.add('visible');
              }
            });
          },
          { threshold: 0.12, rootMargin: '0px 0px -30px 0px' }
        );
        document.querySelectorAll('[data-animate]').forEach((el) => observer.observe(el));
      }

      // ── i18n ──
      const defaultLang = 'lt';

      async function loadTranslations(lang: string) {
        try {
          const mod = await import(`../i18n/${lang}.json`);
          const json = mod.default;
          function resolve(obj: any, path: string): string {
            return path.split('.').reduce((o, k) => o?.[k], obj) ?? '';
          }
          document.querySelectorAll('[data-i18n]').forEach((el) => {
            const key = (el as HTMLElement).dataset.i18n!;
            const val = resolve(json, key);
            if (val) el.textContent = val;
          });
        } catch { /* silent */ }
      }

      function setLang(lang: string) {
        localStorage.setItem('lang', lang);
        loadTranslations(lang);
        document.querySelectorAll('[data-lang-btn]').forEach((btn) => {
          btn.classList.toggle('active', (btn as HTMLElement).dataset.langBtn === lang);
        });
      }

      // Init
      const savedLang = localStorage.getItem('lang') || defaultLang;
      document.querySelectorAll('[data-lang-btn]').forEach((btn) => {
        btn.classList.toggle('active', (btn as HTMLElement).dataset.langBtn === savedLang);
        btn.addEventListener('click', () => setLang((btn as HTMLElement).dataset.langBtn!));
      });
      if (savedLang !== defaultLang) loadTranslations(savedLang);
    </script>
  </body>
</html>

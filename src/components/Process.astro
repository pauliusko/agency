---
const steps = [
  { num: '01', title: 'Analizė', desc: 'Gilinamės į jūsų verslą, rinką ir konkurentus.', active: true },
  { num: '02', title: 'Strategija', desc: 'Sukuriame duomenimis pagrįstą veiksmų planą.' },
  { num: '03', title: 'Dizainas', desc: 'Projektuojame vizualinę tapatybę ir vartotojo sąsają.' },
  { num: '04', title: 'Kūrimas', desc: 'Realizuojame sprendimą naudodami moderniausias technologijas.' },
  { num: '05', title: 'Paleidimas', desc: 'Startuojame, testuojame ir optimizuojame veikimą.' },
  { num: '06', title: 'Optimizavimas', desc: 'Nuolatinė optimizacija ir plėtra pagal duomenis.' },
];
---

<section class="process" id="process">
  <div class="container">
    <div class="process__header">
      <div class="process__header-left" data-animate>
        <span class="process__num">04 — <span data-i18n="process.label">Procesas</span></span>
        <h2 class="process__title" data-i18n="process.title">KAIP MES<br/>DIRBAME</h2>
      </div>
    </div>

    <div class="process__steps">
      {steps.map((step, idx) => (
        <div class={`process__step ${step.active ? 'process__step--active' : ''}`} data-animate data-animate-delay={String(idx + 1)}>
          <span class="process__step-num">{step.num}</span>
          <h3 class="process__step-title">{step.title}</h3>
          <p class="process__step-desc">{step.desc}</p>
        </div>
      ))}
      <div class="process__line" aria-hidden="true"></div>
    </div>
  </div>

  <div class="container">
    <div class="process__ai" data-animate>
      <span class="process__ai-badge">AI POWERED</span>
      <h3 class="process__ai-title">KODAS, KURIS DIRBA.</h3>
      <p class="process__ai-desc">
        Integruojame dirbtinį intelektą į verslo procesus — nuo automatizuoto kodo generavimo iki išmaniųjų analitikos sprendimų. AI technologijos leidžia mums dirbti 3x greičiau ir efektyviau.
      </p>
      <div class="process__ai-tools">
        <div class="process__ai-tool">
          <span class="process__ai-tool-icon">▲</span>
          <span>Cursor</span>
        </div>
        <div class="process__ai-tool">
          <span class="process__ai-tool-icon">◆</span>
          <span>Claude</span>
        </div>
        <div class="process__ai-tool">
          <span class="process__ai-tool-icon">●</span>
          <span>OpenAI</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .process {
    padding: 120px 0;
  }

  .process__header {
    margin-bottom: 64px;
  }

  .process__num {
    font-size: 11px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--accent);
    display: block;
    margin-bottom: 16px;
  }

  .process__title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(48px, 6vw, 96px);
    line-height: 0.9;
    font-weight: 400;
  }

  .process__steps {
    display: flex;
    gap: 0;
    position: relative;
    isolation: isolate;
  }

  .process__line {
    position: absolute;
    top: 38px;
    left: 0;
    right: 0;
    height: 1px;
    background: var(--border);
    z-index: -1;
  }

  .process__step {
    flex: 1;
    position: relative;
    padding-right: 16px;
    cursor: default;
  }

  .process__step-num {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 64px;
    color: var(--border);
    line-height: 1;
    display: block;
    margin-bottom: 16px;
    transition: color 0.3s;
    position: relative;
    z-index: 1;
    background: var(--bg);
    padding-right: 8px;
  }

  .process__step--active .process__step-num {
    color: var(--accent);
  }

  .process__step:hover .process__step-num {
    color: var(--accent);
  }

  .process__step-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 22px;
    font-weight: 400;
    letter-spacing: 1px;
    margin-bottom: 8px;
    transition: color 0.3s;
  }

  .process__step:hover .process__step-title {
    color: var(--accent);
  }

  .process__step-desc {
    font-size: 13px;
    color: var(--text-muted);
    line-height: 1.7;
    max-width: 220px;
    transition: color 0.3s;
  }

  .process__step:hover .process__step-desc {
    color: var(--text);
  }

  /* AI Section */
  .process__ai {
    margin-top: 80px;
    background: var(--bg2);
    border: 1px solid var(--border);
    padding: 48px;
    position: relative;
    overflow: hidden;
  }

  .process__ai::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 100% 0%, rgba(200, 247, 58, 0.06), transparent 60%);
    pointer-events: none;
  }

  .process__ai-badge {
    font-family: 'Share Tech Mono', monospace;
    font-size: 9px;
    letter-spacing: 3px;
    color: var(--accent);
    display: block;
    margin-bottom: 16px;
    opacity: 0.7;
  }

  .process__ai-title {
    font-family: 'Share Tech Mono', monospace;
    font-size: clamp(28px, 4vw, 48px);
    color: var(--accent);
    line-height: 1;
    margin-bottom: 20px;
    letter-spacing: 2px;
  }

  .process__ai-desc {
    font-size: 15px;
    color: var(--text-muted);
    line-height: 1.8;
    max-width: 560px;
    margin-bottom: 32px;
  }

  .process__ai-tools {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }

  .process__ai-tool {
    display: flex;
    align-items: center;
    gap: 10px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.06);
    padding: 10px 20px;
    transition: border-color 0.3s, background 0.3s;
  }

  .process__ai-tool:hover {
    background: rgba(200, 247, 58, 0.04);
    border-color: rgba(200, 247, 58, 0.2);
  }

  .process__ai-tool-icon {
    color: var(--accent);
    font-size: 14px;
  }

  .process__ai-tool span:last-child {
    font-family: 'Share Tech Mono', monospace;
    font-size: 12px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  @media (max-width: 768px) {
    .process__steps {
      flex-direction: column;
      gap: 32px;
    }

    .process__line {
      top: 0;
      bottom: 0;
      left: 30px;
      right: auto;
      width: 1px;
      height: auto;
    }

    .process__step {
      padding-left: 72px;
      padding-right: 0;
    }

    .process__step-num {
      position: absolute;
      left: 0;
      top: 0;
      font-size: 40px;
    }

    .process__ai {
      padding: 32px 24px;
    }
  }
</style>

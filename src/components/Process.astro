---
const steps = [
  { num: '01', title: 'Analizė', desc: 'Gilinamės į jūsų verslą, rinką ir konkurentus.', icon: '◎' },
  { num: '02', title: 'Strategija', desc: 'Sukuriame duomenimis pagrįstą veiksmų planą.', icon: '◈' },
  { num: '03', title: 'Dizainas', desc: 'Projektuojame vizualinę tapatybę ir vartotojo sąsają.', icon: '◇' },
  { num: '04', title: 'Kūrimas', desc: 'Realizuojame sprendimą naudodami moderniausias technologijas.', icon: '▣' },
  { num: '05', title: 'Paleidimas', desc: 'Startuojame, testuojame ir optimizuojame veikimą.', icon: '▲' },
  { num: '06', title: 'Optimizavimas', desc: 'Nuolatinė optimizacija ir plėtra pagal duomenis.', icon: '◉' },
];
---

<section class="process" id="process">
  <div class="container">
    <div class="process__header">
      <div class="process__header-left" data-animate>
        <span class="process__num">04 — <span data-i18n="process.label">Procesas</span></span>
        <h2 class="process__title" data-i18n="process.title">KAIP MES<br/>DIRBAME</h2>
      </div>
    </div>

    <div class="process__grid">
      {steps.map((step, idx) => (
        <div class="process__card" data-animate data-animate-delay={String(idx + 1)}>
          <div class="process__card-inner">
            <div class="process__card-top">
              <span class="process__card-icon">{step.icon}</span>
              <span class="process__card-num">{step.num}</span>
            </div>
            <h3 class="process__card-title">{step.title}</h3>
            <p class="process__card-desc">{step.desc}</p>
            <div class="process__card-line"></div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .process {
    padding: 120px 0;
  }

  .process__header {
    margin-bottom: 64px;
  }

  .process__num {
    font-size: 11px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--accent);
    display: block;
    margin-bottom: 16px;
  }

  .process__title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(48px, 6vw, 96px);
    line-height: 0.9;
    font-weight: 400;
  }

  .process__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
  }

  .process__card {
    background: var(--bg2);
    position: relative;
    overflow: hidden;
    transition: background 0.4s;
  }

  .process__card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(
      circle at 50% 0%,
      rgba(200, 247, 58, 0.06),
      transparent 70%
    );
    opacity: 0;
    transition: opacity 0.4s;
    pointer-events: none;
  }

  .process__card:hover {
    background: #141414;
  }

  .process__card:hover::before {
    opacity: 1;
  }

  .process__card-inner {
    padding: 40px 32px;
    height: 100%;
    display: flex;
    flex-direction: column;
  }

  .process__card-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 24px;
  }

  .process__card-icon {
    font-size: 24px;
    color: var(--accent);
    opacity: 0.4;
    transition: opacity 0.3s, transform 0.3s;
  }

  .process__card:hover .process__card-icon {
    opacity: 1;
    transform: scale(1.2);
  }

  .process__card-num {
    font-family: 'Share Tech Mono', monospace;
    font-size: 11px;
    letter-spacing: 3px;
    color: var(--text-muted);
    opacity: 0.4;
    transition: opacity 0.3s;
  }

  .process__card:hover .process__card-num {
    opacity: 1;
    color: var(--accent);
  }

  .process__card-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 28px;
    font-weight: 400;
    letter-spacing: 2px;
    margin-bottom: 12px;
    transition: color 0.3s;
  }

  .process__card:hover .process__card-title {
    color: var(--accent);
  }

  .process__card-desc {
    font-size: 14px;
    color: var(--text-muted);
    line-height: 1.7;
    transition: color 0.3s;
    flex: 1;
  }

  .process__card:hover .process__card-desc {
    color: var(--text);
  }

  .process__card-line {
    width: 0;
    height: 2px;
    background: var(--accent);
    margin-top: 24px;
    transition: width 0.5s ease;
  }

  .process__card:hover .process__card-line {
    width: 100%;
  }

  @media (max-width: 1000px) {
    .process__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .process__grid {
      grid-template-columns: 1fr;
    }
  }
</style>

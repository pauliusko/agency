---
---

<section class="hero" id="hero">
  <canvas id="hero-canvas"></canvas>
  <div class="container hero__content">
    <span class="hero__label" data-animate data-i18n="hero.label">Digital agency · dirbame visame pasaulyje</span>
    <h1 class="hero__title">
      <span class="hero__line hero__line--outline" data-animate data-animate-delay="1" data-i18n="hero.line1">WEB</span>
      <span class="hero__line hero__line--solid" data-animate data-animate-delay="2" data-i18n="hero.line2">BRAND</span>
      <span class="hero__line hero__line--outline" data-animate data-animate-delay="3" data-i18n="hero.line3">GROWTH.</span>
    </h1>
    <div class="hero__bottom">
      <div class="hero__bottom-left">
        <p class="hero__tagline" data-animate data-animate-delay="4" data-i18n="hero.tagline">
          Rinkiniai, atskiras svetainių kūrimas, reklama ir AI — viename vietoje.
        </p>
        <a href="#contact" class="hero__cta" data-animate data-animate-delay="5" data-i18n="hero.cta">PRADĖKIME DIRBTI →</a>
      </div>
      <div class="hero__stats">
        <div class="hero__stat" data-animate data-animate-delay="5">
          <span class="hero__stat-value" data-count="20" data-suffix="+">0</span>
          <span class="hero__stat-label" data-i18n="hero.stats.projects">Projektų</span>
        </div>
        <div class="hero__stat" data-animate data-animate-delay="6">
          <span class="hero__stat-value" data-count="3" data-suffix="x">0</span>
          <span class="hero__stat-label" data-i18n="hero.stats.roi">ROI vid.</span>
        </div>
        <div class="hero__stat" data-animate data-animate-delay="7">
          <span class="hero__stat-value" data-count="5" data-suffix="+">0</span>
          <span class="hero__stat-label" data-i18n="hero.stats.years">Metų patirties</span>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  // ── Hero Canvas Particles ──
  const canvas = document.getElementById('hero-canvas') as HTMLCanvasElement;
  if (canvas) {
    const ctx = canvas.getContext('2d')!;
    const dpr = window.devicePixelRatio || 1;
    let w = 0, h = 0;
    let mouseX = -1000, mouseY = -1000;

    function resizeCanvas() {
      const rect = canvas.parentElement!.getBoundingClientRect();
      w = rect.width;
      h = rect.height;
      canvas.width = w * dpr;
      canvas.height = h * dpr;
      canvas.style.width = rect.width + 'px';
      canvas.style.height = rect.height + 'px';
      ctx.setTransform(1, 0, 0, 1, 0, 0);
      ctx.scale(dpr, dpr);
    }

    canvas.addEventListener('mousemove', (e) => {
      const rect = canvas.getBoundingClientRect();
      mouseX = e.clientX - rect.left;
      mouseY = e.clientY - rect.top;
    });
    canvas.addEventListener('mouseleave', () => {
      mouseX = -1000;
      mouseY = -1000;
    });

    const particles: { x: number; y: number; vx: number; vy: number; s: number; baseAlpha: number; driftPhase: number; driftSpeed: number }[] = [];

    function initParticles() {
      particles.length = 0;
      const count = Math.min(140, Math.floor(w * h / 6000));
      for (let i = 0; i < count; i++) {
        particles.push({
          x: Math.random() * w,
          y: Math.random() * h,
          vx: (Math.random() - 0.5) * 0.6,
          vy: (Math.random() - 0.5) * 0.6,
          s: 0.5 + Math.random() * 2,
          baseAlpha: 0.3 + Math.random() * 0.4,
          driftPhase: Math.random() * Math.PI * 2,
          driftSpeed: 0.3 + Math.random() * 0.5,
        });
      }
    }

    function draw() {
      ctx.clearRect(0, 0, w, h);
      const time = Date.now() * 0.001;

      for (let i = 0; i < particles.length; i++) {
        const p = particles[i];

        // Mouse repulsion
        const mdx = p.x - mouseX;
        const mdy = p.y - mouseY;
        const mdist = Math.sqrt(mdx * mdx + mdy * mdy);
        if (mdist < 120) {
          const force = (120 - mdist) / 120 * 0.3;
          p.vx += (mdx / mdist) * force;
          p.vy += (mdy / mdist) * force;
        }

        // Continuous drift — particles never stop
        const drift = 0.15;
        p.vx += Math.cos(time * p.driftSpeed + p.driftPhase) * drift * 0.02;
        p.vy += Math.sin(time * p.driftSpeed + p.driftPhase + 1.5) * drift * 0.02;

        // Dampen velocity but keep a minimum
        p.vx *= 0.98;
        p.vy *= 0.98;
        const speed = Math.sqrt(p.vx * p.vx + p.vy * p.vy);
        if (speed < 0.15) {
          const angle = time * p.driftSpeed + p.driftPhase;
          p.vx += Math.cos(angle) * 0.08;
          p.vy += Math.sin(angle) * 0.08;
        }

        p.x += p.vx;
        p.y += p.vy;
        if (p.x < 0 || p.x > w) p.vx *= -1;
        if (p.y < 0 || p.y > h) p.vy *= -1;

        // Pulsing glow
        const pulse = 0.7 + Math.sin(time * 2 + i) * 0.3;
        const alpha = p.baseAlpha * pulse;

        ctx.beginPath();
        ctx.arc(p.x, p.y, p.s, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(200,247,58,${alpha})`;
        ctx.fill();

        // Connection lines
        for (let j = i + 1; j < particles.length; j++) {
          const q = particles[j];
          const dx = p.x - q.x;
          const dy = p.y - q.y;
          const dist = Math.sqrt(dx * dx + dy * dy);
          if (dist < 150) {
            ctx.beginPath();
            ctx.moveTo(p.x, p.y);
            ctx.lineTo(q.x, q.y);
            ctx.strokeStyle = `rgba(200,247,58,${(1 - dist / 150) * 0.15})`;
            ctx.lineWidth = 0.5;
            ctx.stroke();
          }
        }
      }
      requestAnimationFrame(draw);
    }

    // Wait for full page load so layout is complete before measuring
    window.addEventListener('load', () => {
      resizeCanvas();
      initParticles();
      requestAnimationFrame(draw);
    });

    window.addEventListener('resize', () => {
      resizeCanvas();
      initParticles();
    });
  }

  // ── Counter Animation ──
  if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    const counters = document.querySelectorAll<HTMLElement>('[data-count]');
    const cObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const el = entry.target as HTMLElement;
            const target = parseFloat(el.dataset.count || '0');
            const suffix = el.dataset.suffix || '';
            const duration = 1500;
            const start = performance.now();
            function tick(now: number) {
              const progress = Math.min((now - start) / duration, 1);
              const eased = 1 - Math.pow(1 - progress, 3);
              const current = target * eased;
              el.textContent = (Number.isInteger(target) ? Math.round(current) : current.toFixed(0)) + suffix;
              if (progress < 1) requestAnimationFrame(tick);
            }
            requestAnimationFrame(tick);
            cObserver.unobserve(el);
          }
        });
      },
      { threshold: 0.5 }
    );
    counters.forEach((el) => cObserver.observe(el));
  }
</script>

<style is:inline>
  .hero__line--outline {
    -webkit-text-stroke: 1.5px rgba(240, 237, 228, 0.4);
    color: transparent;
  }
</style>

<style>
  .hero {
    min-height: 100vh;
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: flex-end;
  }

  #hero-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    pointer-events: auto;
  }

  .hero__content {
    position: relative;
    z-index: 1;
    padding-bottom: 64px;
    width: 100%;
    min-width: 0;
    max-width: 100%;
  }

  .hero__label {
    display: block;
    font-size: 11px;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 24px;
  }

  .hero__title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(52px, 12vw, 180px);
    line-height: 0.88;
    font-weight: 400;
    max-width: 100%;
    overflow-wrap: anywhere;
  }

  .hero__line {
    display: block;
  }

  .hero__line--solid {
    color: var(--text);
  }

  .hero__line--accent {
    color: var(--accent);
  }

  .hero__bottom {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-top: 48px;
  }

  .hero__bottom-left {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .hero__tagline {
    max-width: 320px;
    font-size: 16px;
    color: var(--text-muted);
    line-height: 1.7;
  }

  .hero__cta {
    display: inline-block;
    padding: 16px 32px;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 16px;
    letter-spacing: 3px;
    color: #0a0a0a;
    background: var(--accent);
    border: none;
    transition: background 0.2s, transform 0.2s;
    text-align: center;
    width: fit-content;
  }

  .hero__cta:hover {
    background: #d4ff3a;
    transform: translateY(-2px);
  }

  .hero__stats {
    display: flex;
    flex-wrap: wrap;
    gap: clamp(16px, 4vw, 40px);
    text-align: left;
    max-width: 100%;
  }

  .hero__stat {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .hero__stat-value {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(36px, 9vw, 52px);
    color: var(--text);
    line-height: 1;
  }

  .hero__stat-label {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--text-muted);
  }

  @media (max-width: 768px) {
    .hero {
      align-items: center;
    }

    .hero__content {
      padding-bottom: 32px;
      padding-top: 100px;
    }

    .hero__bottom {
      flex-direction: column;
      align-items: flex-start;
      gap: 24px;
    }

    .hero__cta {
      width: 100%;
      text-align: center;
    }

    .hero__stats {
      text-align: left;
    }
  }
</style>

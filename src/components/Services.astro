---
import lt from '../i18n/lt.json';

type Card = {
  num: string;
  duration: string;
  title: string;
  desc: string;
  bullets: string[];
  price: string;
  priceNote: string;
  trialPrice?: string;
  trialLabel?: string;
};

const cardData = lt.services.cardData;
const categories: { id: keyof typeof cardData; tabKey: string }[] = [
  { id: 'bundles', tabKey: 'services.tab.bundles' },
  { id: 'website', tabKey: 'services.tab.website' },
  { id: 'ads', tabKey: 'services.tab.ads' },
  { id: 'ai', tabKey: 'services.tab.ai' },
];
const supportPlans = cardData.support;
---

<section class="services" id="services">
  <div class="container">
    <div class="services__header">
      <div class="services__header-left" data-animate>
        <span class="services__num">02 — <span data-i18n="services.label">Paslaugos</span></span>
        <h2 class="services__title" data-animate data-i18n="services.title" data-i18n-br="true">PASLAUGOS<br />IR KAINOS</h2>
      </div>
      <p class="services__header-desc" data-animate data-animate-delay="1" data-i18n="services.desc">
        Rinkiniai, atskiras svetainių kūrimas, reklama ir AI — viename vietoje.
      </p>
    </div>

    <div class="services__tabs" data-animate>
      {categories.map((cat, i) => (
        <button
          type="button"
          class:list={['services__tab', { 'services__tab--active': i === 0 }]}
          data-tab={cat.id}
          data-i18n={cat.tabKey}
        >
          {lt.services.tab[cat.id as keyof typeof lt.services.tab]}
        </button>
      ))}
    </div>

    {
      categories.map((cat, catIdx) => (
        <div class:list={['services__category', { 'services__category--active': catIdx === 0 }]} data-category={cat.id}>
          <div class="services__grid">
            {(cardData[cat.id] as Card[]).map((card, idx) => (
              <div class="service-card" data-animate data-animate-delay={String(idx + 1)} data-svc-cat={cat.id} data-svc-idx={idx}>
                <div class="service-card__top">
                  <span class="service-card__num">{card.num}</span>
                  <span class="service-card__badge">{card.duration}</span>
                </div>
                <h3 class="service-card__title">{card.title}</h3>
                <p class="service-card__desc">{card.desc}</p>
                <ul class="service-card__bullets">
                  {card.bullets.map((b) => (
                    <li>↘ {b}</li>
                  ))}
                </ul>
                <div class="service-card__bottom">
                  {card.trialPrice ? (
                    <div class="service-card__price-wrap service-card__price-wrap--has-trial">
                      <span class="service-card__trial-badge">{card.trialLabel}</span>
                      <div class="service-card__trial-row">
                        <span class="service-card__trial-price">{card.trialPrice}</span>
                        <span class="service-card__price-note">{card.priceNote}</span>
                      </div>
                      <div class="service-card__old-row">
                        <span class="service-card__regular-label">toliau —</span>
                        <span class="service-card__price service-card__price--old">{card.price}</span>
                        <span class="service-card__price-note service-card__price-note--old">{card.priceNote}</span>
                      </div>
                    </div>
                  ) : (
                    <div class="service-card__price-wrap">
                      <span class="service-card__price">{card.price}</span>
                      <span class="service-card__price-note">{card.priceNote}</span>
                    </div>
                  )}
                  <a href="#contact" class="service-card__cta" data-i18n="services.cta">SIŲSTI UŽKLAUSĄ →</a>
                </div>
              </div>
            ))}
          </div>
        </div>
      ))
    }

    <div class="services__support" data-animate>
      <h3 class="services__support-title" data-i18n="services.supportTitle">PALAIKYMAS IR PAPILDOMOS PASLAUGOS</h3>
      <div class="services__support-grid">
        {
          supportPlans.map((plan, idx) => (
            <div class="support-card" data-svc-support={idx}>
              <h4 class="support-card__title">{plan.title}</h4>
              <p class="support-card__desc">{plan.desc}</p>
              <span class="support-card__price">{plan.price}</span>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<script>
  function applyServiceCards(json: any) {
    const data = json.services?.cardData;
    if (!data) return;

    document.querySelectorAll<HTMLElement>('[data-svc-cat]').forEach((el) => {
      const cat = el.dataset.svcCat as string;
      const idx = parseInt(el.dataset.svcIdx || '0', 10);
      const cards = data[cat] as { duration: string; title: string; desc: string; bullets: string[]; price: string; priceNote: string; trialPrice?: string; trialLabel?: string }[];
      const card = cards?.[idx];
      if (!card) return;

      const badge = el.querySelector('.service-card__badge');
      const title = el.querySelector('.service-card__title');
      const desc = el.querySelector('.service-card__desc');
      if (badge) badge.textContent = card.duration;
      if (title) title.textContent = card.title;
      if (desc) desc.textContent = card.desc;

      // Handle trial pricing
      const trialBadge = el.querySelector('.service-card__trial-badge');
      const trialPrice = el.querySelector('.service-card__trial-price');
      const oldPrice = el.querySelector('.service-card__price--old');
      const regularLabel = el.querySelector('.service-card__regular-label');
      const plainPrice = el.querySelector('.service-card__price:not(.service-card__price--old)');

      if (trialBadge && card.trialLabel) trialBadge.textContent = card.trialLabel;
      if (trialPrice && card.trialPrice) trialPrice.textContent = card.trialPrice;
      if (oldPrice) oldPrice.textContent = card.price;
      if (regularLabel) {
        const lang = document.documentElement.lang || 'lt';
        regularLabel.textContent = lang === 'en' ? 'then —' : lang === 'ru' ? 'далее —' : 'toliau —';
      }
      if (plainPrice && !trialBadge) plainPrice.textContent = card.price;

      const notes = el.querySelectorAll('.service-card__price-note');
      notes.forEach(n => { if (n) n.textContent = card.priceNote; });

      const lis = el.querySelectorAll('.service-card__bullets li');
      card.bullets.forEach((b, i) => {
        if (lis[i]) lis[i].textContent = `↘ ${b}`;
      });
    });

    const sup = data.support;
    if (Array.isArray(sup)) {
      document.querySelectorAll<HTMLElement>('[data-svc-support]').forEach((el) => {
        const idx = parseInt(el.dataset.svcSupport || '0', 10);
        const plan = sup[idx];
        if (!plan) return;
        const t = el.querySelector('.support-card__title');
        const d = el.querySelector('.support-card__desc');
        const p = el.querySelector('.support-card__price');
        if (t) t.textContent = plan.title;
        if (d) d.textContent = plan.desc;
        if (p) p.textContent = plan.price;
      });
    }
  }

  window.addEventListener('gronk:locale', ((e: CustomEvent<{ json: any }>) => {
    if (e.detail?.json) applyServiceCards(e.detail.json);
  }) as EventListener);
</script>

<script>
  document.querySelectorAll<HTMLElement>('.service-card').forEach((card) => {
    card.addEventListener('mousemove', (e) => {
      const rect = card.getBoundingClientRect();
      card.style.setProperty('--mouse-x', `${e.clientX - rect.left}px`);
      card.style.setProperty('--mouse-y', `${e.clientY - rect.top}px`);
    });
  });

  document.querySelectorAll<HTMLElement>('.services__tab').forEach((tab) => {
    tab.addEventListener('click', () => {
      const targetId = tab.dataset.tab;

      document.querySelectorAll('.services__tab').forEach((t) => t.classList.remove('services__tab--active'));
      tab.classList.add('services__tab--active');

      document.querySelectorAll('.services__category').forEach((cat) => {
        const el = cat as HTMLElement;
        if (el.dataset.category === targetId) el.classList.add('services__category--active');
        else el.classList.remove('services__category--active');
      });
    });
  });
</script>

<style>
  .services {
    padding: 72px 0;
  }

  .services__header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 40px;
  }

  .services__num {
    font-size: 11px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--accent);
    display: block;
    margin-bottom: 16px;
  }

  .services__title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(48px, 6vw, 96px);
    line-height: 0.9;
    font-weight: 400;
  }

  .services__header-desc {
    max-width: 320px;
    font-size: 15px;
    color: var(--text-muted);
    line-height: 1.7;
    padding-top: 24px;
  }

  .services__tabs {
    display: flex;
    flex-wrap: wrap;
    gap: 4px 8px;
    margin-bottom: 28px;
    border-bottom: 1px solid var(--border);
  }

  .services__tab {
    padding: 14px 22px;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 16px;
    letter-spacing: 2px;
    color: var(--text-muted);
    background: none;
    border: none;
    border-bottom: 2px solid transparent;
    cursor: pointer;
    transition: color 0.3s, border-color 0.3s;
    position: relative;
    bottom: -1px;
  }

  .services__tab:hover {
    color: var(--text);
  }

  .services__tab--active {
    color: var(--accent);
    border-bottom-color: var(--accent);
  }

  .services__category {
    display: none;
  }

  .services__category--active {
    display: block;
  }

  .services__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 2px;
  }

  .service-card {
    background: var(--bg2);
    padding: 40px 32px;
    position: relative;
    overflow: hidden;
    border-bottom: 3px solid transparent;
    transition: border-color 0.3s, background 0.3s;
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .service-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(
      300px circle at var(--mouse-x, 50%) var(--mouse-y, 50%),
      rgba(200, 247, 58, 0.05),
      transparent 60%
    );
    opacity: 0;
    transition: opacity 0.3s;
    pointer-events: none;
  }

  .service-card:hover {
    border-bottom-color: var(--accent);
    background: #141414;
  }

  .service-card:hover::before {
    opacity: 1;
  }

  .service-card__top {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .service-card__num {
    font-size: 11px;
    letter-spacing: 3px;
    color: var(--text-muted);
  }

  .service-card__badge {
    background: var(--bg3);
    padding: 4px 12px;
    font-size: 10px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .service-card__title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(22px, 3vw, 32px);
    letter-spacing: 1px;
    font-weight: 400;
    margin-top: 24px;
  }

  .service-card__desc {
    font-size: 13px;
    color: var(--text-muted);
    margin-top: 8px;
    margin-bottom: 24px;
    line-height: 1.6;
  }

  .service-card__bullets {
    display: flex;
    flex-direction: column;
  }

  .service-card__bullets li {
    font-size: 13px;
    line-height: 2;
    color: var(--text-muted);
  }

  .service-card__bottom {
    display: flex;
    flex-direction: column;
    gap: 16px;
    margin-top: auto;
    padding-top: 32px;
  }

  .service-card__price-wrap {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .service-card__price-wrap--has-trial {
    gap: 6px;
  }

  /* ── Trial badge ── */
  .service-card__trial-badge {
    display: inline-block;
    padding: 4px 12px;
    background: var(--accent);
    color: #0a0a0a;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 12px;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    font-weight: 700;
    align-self: flex-start;
  }

  /* ── Trial price row ── */
  .service-card__trial-row {
    display: flex;
    align-items: baseline;
    gap: 6px;
  }

  .service-card__trial-price {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(32px, 5vw, 48px);
    color: var(--accent);
    line-height: 1;
    word-break: break-word;
  }

  .service-card__trial-row .service-card__price-note {
    color: var(--accent);
    opacity: 0.6;
  }

  /* ── Old price row ── */
  .service-card__old-row {
    display: flex;
    align-items: baseline;
    gap: 6px;
  }

  .service-card__regular-label {
    font-size: 11px;
    color: var(--text-muted);
    opacity: 0.4;
    letter-spacing: 0.5px;
  }

  .service-card__price--old {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(18px, 2.5vw, 22px);
    color: var(--text-muted);
    opacity: 0.35;
    text-decoration: line-through;
    text-decoration-color: rgba(255, 80, 80, 0.55);
    text-decoration-thickness: 2px;
    line-height: 1;
  }

  .service-card__price-note--old {
    opacity: 0.25 !important;
  }

  /* ── Standard price (non-trial) ── */
  .service-card__price {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(28px, 5vw, 40px);
    color: var(--accent);
    line-height: 1;
    word-break: break-word;
  }

  .service-card__price-note {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--text-muted);
    opacity: 0.6;
  }

  .service-card__cta {
    display: block;
    text-align: center;
    padding: 14px 0;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 14px;
    letter-spacing: 3px;
    color: var(--accent);
    border: 1px solid var(--accent);
    transition: background 0.2s, color 0.2s;
  }

  .service-card__cta:hover {
    background: var(--accent);
    color: #0a0a0a;
  }

  @media (max-width: 900px) {
    .services__grid {
      grid-template-columns: 1fr !important;
    }
  }

  @media (max-width: 1024px) {
    .services__support-grid {
      grid-template-columns: 1fr !important;
    }
  }

  @media (max-width: 600px) {
    .services {
      padding: 56px 0;
    }

    .services__header {
      flex-direction: column;
      gap: 16px;
      margin-bottom: 28px;
    }

    .services__tab {
      padding: 12px 16px;
      font-size: 14px;
    }
  }

  .services__support {
    margin-top: 48px;
    padding-top: 40px;
    border-top: 1px solid var(--border);
  }

  .services__support-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 22px;
    letter-spacing: 2px;
    color: var(--text-muted);
    margin-bottom: 28px;
  }

  .services__support-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
  }

  .support-card {
    background: var(--bg2);
    padding: 32px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    border-top: 2px solid transparent;
    transition: border-color 0.3s, background 0.3s;
    min-width: 0;
  }

  .support-card:hover {
    border-top-color: var(--accent);
    background: #141414;
  }

  .support-card__title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 22px;
    letter-spacing: 1px;
    font-weight: 400;
  }

  .support-card__desc {
    font-size: 13px;
    color: var(--text-muted);
    line-height: 1.6;
    flex: 1;
  }

  .support-card__price {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 28px;
    color: var(--accent);
    line-height: 1;
    margin-top: 8px;
    word-break: break-word;
  }
</style>

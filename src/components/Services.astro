---

<section class="services" id="services">
  <div class="container">
    <div class="services__header">
      <div class="services__header-left" data-animate>
        <span class="services__num">02 — <span data-i18n="services.label">Paslaugos</span></span>
        <h2 class="services__title" data-i18n="services.title">PASLAUGOS<br/>IR KAINOS</h2>
      </div>
      <p class="services__header-desc" data-animate data-animate-delay="1" data-i18n="services.desc">
        Pilnas skaitmeninių sprendimų spektras — nuo svetainių iki AI automatizacijos.
      </p>
    </div>

    <!-- Category Tabs -->
    <div class="services__tabs" data-animate>
      {categories.map((cat, i) => (
        <button
          class={`services__tab ${i === 0 ? 'services__tab--active' : ''}`}
          data-tab={cat.id}
        >
          {cat.label}
        </button>
      ))}
    </div>

    <!-- Category Sections -->
    {categories.map((cat, catIdx) => (
      <div class={`services__category ${catIdx === 0 ? 'services__category--active' : ''}`} data-category={cat.id}>
        <div class="services__grid">
          {cat.cards.map((card, idx) => (
            <div class="service-card" data-animate data-animate-delay={String(idx + 1)}>
              <div class="service-card__top">
                <span class="service-card__num">{card.num}</span>
                <span class="service-card__badge">{card.duration}</span>
              </div>
              <h3 class="service-card__title">{card.title}</h3>
              <p class="service-card__desc">{card.desc}</p>
              <ul class="service-card__bullets">
                {card.bullets.map((b) => (
                  <li>↘ {b}</li>
                ))}
              </ul>
              <div class="service-card__bottom">
                <div class="service-card__price-wrap">
                  <span class="service-card__price">{card.price}</span>
                  <span class="service-card__price-note">{card.priceNote}</span>
                </div>
                <a href="#contact" class="service-card__cta" data-i18n="services.cta">SIŲSTI UŽKLAUSĄ →</a>
              </div>
            </div>
          ))}
        </div>
      </div>
    ))}

    <div class="services__support" data-animate>
      <h3 class="services__support-title">PALAIKYMAS IR PAPILDOMOS PASLAUGOS</h3>
      <div class="services__support-grid">
        {supportPlans.map((plan) => (
          <div class="support-card">
            <h4 class="support-card__title">{plan.title}</h4>
            <p class="support-card__desc">{plan.desc}</p>
            <span class="support-card__price">{plan.price}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  // Service card mouse follow
  document.querySelectorAll<HTMLElement>('.service-card').forEach((card) => {
    card.addEventListener('mousemove', (e) => {
      const rect = card.getBoundingClientRect();
      card.style.setProperty('--mouse-x', `${e.clientX - rect.left}px`);
      card.style.setProperty('--mouse-y', `${e.clientY - rect.top}px`);
    });
  });

  // Category tabs
  document.querySelectorAll<HTMLElement>('.services__tab').forEach((tab) => {
    tab.addEventListener('click', () => {
      const targetId = tab.dataset.tab;

      // Toggle active tab
      document.querySelectorAll('.services__tab').forEach((t) => t.classList.remove('services__tab--active'));
      tab.classList.add('services__tab--active');

      // Toggle active category
      document.querySelectorAll('.services__category').forEach((cat) => {
        const el = cat as HTMLElement;
        if (el.dataset.category === targetId) {
          el.classList.add('services__category--active');
        } else {
          el.classList.remove('services__category--active');
        }
      });
    });
  });
</script>

<style>
  .services {
    padding: 120px 0;
  }

  .services__header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 48px;
  }

  .services__num {
    font-size: 11px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--accent);
    display: block;
    margin-bottom: 16px;
  }

  .services__title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(48px, 6vw, 96px);
    line-height: 0.9;
    font-weight: 400;
  }

  .services__header-desc {
    max-width: 320px;
    font-size: 15px;
    color: var(--text-muted);
    line-height: 1.7;
    padding-top: 24px;
  }

  /* ── Tabs ── */
  .services__tabs {
    display: flex;
    gap: 0;
    margin-bottom: 32px;
    border-bottom: 1px solid var(--border);
  }

  .services__tab {
    padding: 16px 32px;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 18px;
    letter-spacing: 2px;
    color: var(--text-muted);
    background: none;
    border: none;
    border-bottom: 2px solid transparent;
    cursor: pointer;
    transition: color 0.3s, border-color 0.3s;
    position: relative;
    bottom: -1px;
  }

  .services__tab:hover {
    color: var(--text);
  }

  .services__tab--active {
    color: var(--accent);
    border-bottom-color: var(--accent);
  }

  /* ── Categories ── */
  .services__category {
    display: none;
  }

  .services__category--active {
    display: block;
  }

  /* ── Grid ── */
  .services__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2px;
  }

  .services__category[data-category="ads"] .services__grid,
  .services__category[data-category="ai"] .services__grid {
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
  }

  .service-card {
    background: var(--bg2);
    padding: 40px 32px;
    position: relative;
    overflow: hidden;
    border-bottom: 3px solid transparent;
    transition: border-color 0.3s, background 0.3s;
    display: flex;
    flex-direction: column;
  }

  .service-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(
      300px circle at var(--mouse-x, 50%) var(--mouse-y, 50%),
      rgba(200, 247, 58, 0.05),
      transparent 60%
    );
    opacity: 0;
    transition: opacity 0.3s;
    pointer-events: none;
  }

  .service-card:hover {
    border-bottom-color: var(--accent);
    background: #141414;
  }

  .service-card:hover::before {
    opacity: 1;
  }

  .service-card__top {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .service-card__num {
    font-size: 11px;
    letter-spacing: 3px;
    color: var(--text-muted);
  }

  .service-card__badge {
    background: var(--bg3);
    padding: 4px 12px;
    font-size: 10px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .service-card__title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 32px;
    letter-spacing: 1px;
    font-weight: 400;
    margin-top: 24px;
  }

  .service-card__desc {
    font-size: 13px;
    color: var(--text-muted);
    margin-top: 8px;
    margin-bottom: 24px;
    line-height: 1.6;
  }

  .service-card__bullets {
    display: flex;
    flex-direction: column;
  }

  .service-card__bullets li {
    font-size: 13px;
    line-height: 2;
    color: var(--text-muted);
  }

  .service-card__bottom {
    display: flex;
    flex-direction: column;
    gap: 16px;
    margin-top: auto;
    padding-top: 32px;
  }

  .service-card__price-wrap {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .service-card__price {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 40px;
    color: var(--accent);
    line-height: 1;
  }

  .service-card__price-note {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--text-muted);
    opacity: 0.6;
  }

  .service-card__cta {
    display: block;
    text-align: center;
    padding: 14px 0;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 14px;
    letter-spacing: 3px;
    color: var(--accent);
    border: 1px solid var(--accent);
    transition: background 0.2s, color 0.2s;
  }

  .service-card__cta:hover {
    background: var(--accent);
    color: #0a0a0a;
  }

  @media (max-width: 600px) {
    .services__header {
      flex-direction: column;
      gap: 16px;
    }

    .services__grid {
      grid-template-columns: 1fr;
    }

    .services__tabs {
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
    }

    .services__tab {
      padding: 12px 20px;
      font-size: 15px;
      white-space: nowrap;
    }

    .services__support-grid {
      grid-template-columns: 1fr;
    }
  }

  /* Support / Maintenance section */
  .services__support {
    margin-top: 64px;
    padding-top: 48px;
    border-top: 1px solid var(--border);
  }

  .services__support-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 24px;
    letter-spacing: 2px;
    color: var(--text-muted);
    margin-bottom: 32px;
  }

  .services__support-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
  }

  .support-card {
    background: var(--bg2);
    padding: 32px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    border-top: 2px solid transparent;
    transition: border-color 0.3s, background 0.3s;
  }

  .support-card:hover {
    border-top-color: var(--accent);
    background: #141414;
  }

  .support-card__title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 22px;
    letter-spacing: 1px;
    font-weight: 400;
  }

  .support-card__desc {
    font-size: 13px;
    color: var(--text-muted);
    line-height: 1.6;
    flex: 1;
  }

  .support-card__price {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 28px;
    color: var(--accent);
    line-height: 1;
    margin-top: 8px;
  }
</style>

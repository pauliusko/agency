---

<section class="canvas-cards" id="stack">
  <div class="container canvas-cards__inner">
    <div class="canvas-cards__text" data-animate>
      <span class="canvas-cards__label" data-i18n="canvas.techLabel">Technologijos</span>
      <h2 class="canvas-cards__title" data-i18n="canvas.title" data-i18n-br="true">KODAS,<br />KURIS<br />DIRBA.</h2>
      <p class="canvas-cards__desc" data-i18n="canvas.desc">
        Kiekvienas mūsų projektas gimsta iš švaraus kodo, greito dizaino ir duomenimis pagrįstų sprendimų. Diegiame AI sprendimus su Cursor, Claude Code ir kitais įrankiais — nuo svetainės iki automatizacijos.
      </p>
      <div class="canvas-cards__tools" data-animate data-animate-delay="1">
        <span class="canvas-cards__tools-label" data-i18n="stack.label">Dirbame su</span>
        <div class="canvas-cards__tools-row">
          {tools.map((tool) => (
            <div class="canvas-cards__tool">
              <span class="canvas-cards__tool-icon" set:html={tool.svg}></span>
              <span class="canvas-cards__tool-name">{tool.name}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
    <div class="canvas-cards__canvas-wrap" data-animate data-animate-delay="2">
      <canvas id="code-canvas"></canvas>
    </div>
  </div>
</section>

<script>
  const canvas = document.getElementById('code-canvas') as HTMLCanvasElement;
  if (canvas) {
    const ctx = canvas.getContext('2d')!;
    const wrap = canvas.parentElement!;
    const dpr = window.devicePixelRatio || 1;
    let w: number, h: number;

    function resizeCanvas() {
      const rect = wrap.getBoundingClientRect();
      w = rect.width;
      h = rect.height;
      canvas.width = w * dpr;
      canvas.height = h * dpr;
      canvas.style.width = rect.width + 'px';
      canvas.style.height = rect.height + 'px';
      ctx.setTransform(1, 0, 0, 1, 0, 0);
      ctx.scale(dpr, dpr);
    }

    const lines = [
      { text: 'const launch = async () => {', color: '#c8f73a', indent: 0 },
      { text: '  const strategy = analyze(market);', color: '#8b8b8b', indent: 0 },
      { text: '  const design = await create({', color: '#8b8b8b', indent: 0 },
      { text: '    brand: client.vision,', color: '#6B8FF0', indent: 0 },
      { text: '    ux: "premium",', color: '#6B8FF0', indent: 0 },
      { text: '  });', color: '#8b8b8b', indent: 0 },
      { text: '  const site = build(design);', color: '#8b8b8b', indent: 0 },
      { text: '  const ai = deployAI({', color: '#c8f73a', indent: 0 },
      { text: '    agent: "claude-code",', color: '#A78BFA', indent: 0 },
      { text: '    tools: [cursor, chatgpt],', color: '#A78BFA', indent: 0 },
      { text: '    automate: workflows()', color: '#A78BFA', indent: 0 },
      { text: '  });', color: '#8b8b8b', indent: 0 },
      { text: '  const ads = startCampaigns({', color: '#8b8b8b', indent: 0 },
      { text: '    google: trackROI(),', color: '#FF8C42', indent: 0 },
      { text: '    meta: targetAudience()', color: '#FF8C42', indent: 0 },
      { text: '  });', color: '#8b8b8b', indent: 0 },
      { text: '  return { site, ai, ads };', color: '#c8f73a', indent: 0 },
      { text: '};', color: '#c8f73a', indent: 0 },
      { text: '', color: '#8b8b8b', indent: 0 },
      { text: 'launch(); // 🚀 rezultatai', color: '#00D9A6', indent: 0 },
    ];

    let t = 0;
    const charSpeed = 1.05;

    // Floating particles
    const particles = Array.from({ length: 30 }, () => ({
      x: Math.random() * 1,
      y: Math.random() * 1,
      vx: (Math.random() - 0.5) * 0.0005,
      vy: (Math.random() - 0.5) * 0.0005,
      size: 0.5 + Math.random() * 1.5,
      alpha: 0.1 + Math.random() * 0.2,
    }));

    function draw() {
      t += charSpeed;
      ctx.clearRect(0, 0, w, h);

      // Floating background particles
      particles.forEach((p) => {
        p.x += p.vx;
        p.y += p.vy;
        if (p.x < 0 || p.x > 1) p.vx *= -1;
        if (p.y < 0 || p.y > 1) p.vy *= -1;
        ctx.beginPath();
        ctx.arc(p.x * w, p.y * h, p.size, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(200,247,58,${p.alpha})`;
        ctx.fill();
      });

      // Code lines
      const fontSize = Math.max(12, Math.min(14, w * 0.035));
      const lineHeight = fontSize * 1.75;
      const startX = 28;
      const startY = 36;
      let charCount = 0;

      // Line numbers gutter
      lines.forEach((line, i) => {
        const y = startY + i * lineHeight;
        if (y > h - 20) return;
        ctx.font = `${fontSize}px ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace`;
        ctx.textBaseline = 'top';

        // Line number
        ctx.fillStyle = 'rgba(255,255,255,0.1)';
        ctx.textAlign = 'right';
        ctx.fillText(String(i + 1), 18, y);
        ctx.textAlign = 'left';

        // Code text — typed effect
        const visibleChars = Math.max(0, Math.floor(t) - charCount);
        const displayText = line.text.substring(0, Math.min(visibleChars, line.text.length));
        charCount += line.text.length;

        if (displayText.length > 0) {
          ctx.fillStyle = line.color;
          ctx.fillText(displayText, startX, y);

          // Cursor blink at end of current line
          if (visibleChars <= line.text.length && visibleChars > 0) {
            const cursorX = startX + ctx.measureText(displayText).width;
            if (Math.sin(Date.now() * 0.006) > 0) {
              ctx.fillStyle = '#c8f73a';
              ctx.fillRect(cursorX + 2, y, 2, fontSize);
            }
          }
        }
      });

      // Loop the typing after all lines
      const totalChars = lines.reduce((s, l) => s + l.text.length, 0);
      if (Math.floor(t) > totalChars + 40) t = 0;

      requestAnimationFrame(draw);
    }

    // Wait for full page load so layout is complete before measuring
    function syncWrapSize() {
      if (window.matchMedia('(max-width: 768px)').matches) {
        wrap.style.minHeight = 'min(72vw, 420px)';
      } else {
        wrap.style.minHeight = '';
      }
      resizeCanvas();
    }

    window.addEventListener('load', () => {
      syncWrapSize();
      requestAnimationFrame(draw);
    });

    syncWrapSize();
    window.addEventListener('resize', syncWrapSize);
  }
</script>

<style>
  .canvas-cards {
    padding: 56px 0;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  .canvas-cards__inner {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: 36px;
    align-items: start;
    min-width: 0;
  }

  .canvas-cards__label {
    font-size: 10px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--accent);
    display: block;
    margin-bottom: 16px;
  }

  .canvas-cards__title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(48px, 5vw, 72px);
    line-height: 0.9;
    font-weight: 400;
    margin-bottom: 20px;
  }

  .canvas-cards__desc {
    font-size: 14px;
    color: var(--text-muted);
    line-height: 1.7;
    max-width: 340px;
  }

  /* Stack tools integrated */
  .canvas-cards__tools {
    margin-top: 32px;
    padding-top: 24px;
    border-top: 1px solid var(--border);
  }

  .canvas-cards__tools-label {
    display: block;
    font-size: 9px;
    text-transform: uppercase;
    letter-spacing: 3px;
    color: var(--text-muted);
    margin-bottom: 16px;
  }

  .canvas-cards__tools-row {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .canvas-cards__tool {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 8px 12px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.06);
    transition: border-color 0.3s, background 0.3s;
    cursor: default;
  }

  .canvas-cards__tool:hover {
    background: rgba(200, 247, 58, 0.04);
    border-color: rgba(200, 247, 58, 0.2);
  }

  .canvas-cards__tool-icon {
    width: 16px;
    height: 16px;
    color: var(--text-muted);
    transition: color 0.2s;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .canvas-cards__tool-icon :global(svg) {
    width: 100%;
    height: 100%;
  }

  .canvas-cards__tool:hover .canvas-cards__tool-icon {
    color: var(--accent);
  }

  .canvas-cards__tool-name {
    font-size: 9px;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--text-muted);
    transition: color 0.2s;
    white-space: nowrap;
  }

  .canvas-cards__tool:hover .canvas-cards__tool-name {
    color: var(--accent);
  }

  .canvas-cards__canvas-wrap {
    background: #111;
    border-radius: 16px;
    overflow: hidden;
    aspect-ratio: 4 / 3;
    position: relative;
    border: 1px solid var(--border);
    min-height: 260px;
    width: 100%;
    max-width: 100%;
  }

  .canvas-cards__canvas-wrap canvas {
    width: 100%;
    height: 100%;
    display: block;
  }

  @media (max-width: 768px) {
    .canvas-cards__inner {
      grid-template-columns: 1fr;
    }

    .canvas-cards__canvas-wrap {
      aspect-ratio: auto;
      min-height: min(72vw, 420px);
    }
  }
</style>

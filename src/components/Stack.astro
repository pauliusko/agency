---

<section class="stack" id="stack">
  <div class="container">
    <span class="stack__label" data-animate data-i18n="stack.label">Dirbame su</span>
    <div class="stack__row">
      {tools.map((tool, idx) => (
        <div class="stack__item" data-animate data-animate-delay={String(Math.min(idx + 1, 8))}>
          <span class="stack__icon" set:html={tool.svg}></span>
          <span class="stack__name">{tool.name}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .stack {
    padding: 80px 0;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  .stack__label {
    display: block;
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 3px;
    color: var(--text-muted);
    margin-bottom: 32px;
  }

  .stack__row {
    display: flex;
    flex-wrap: wrap;
    gap: 0;
  }

  .stack__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    padding: 24px 32px;
    border-right: 1px solid var(--border);
    transition: background 0.2s;
    cursor: default;
  }

  .stack__item:last-child {
    border-right: none;
  }

  .stack__item:hover {
    background: var(--bg2);
  }

  .stack__item:hover .stack__name {
    color: var(--accent);
  }

  .stack__item:hover .stack__icon {
    color: var(--accent);
  }

  .stack__icon {
    width: 28px;
    height: 28px;
    color: var(--text-muted);
    transition: color 0.2s;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .stack__icon :global(svg) {
    width: 100%;
    height: 100%;
  }

  .stack__name {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--text-muted);
    transition: color 0.2s;
    white-space: nowrap;
  }

  @media (max-width: 768px) {
    .stack__row {
      flex-wrap: wrap;
    }

    .stack__item {
      flex: 0 0 25%;
      border-right: none;
      border-bottom: 1px solid var(--border);
      padding: 20px 16px;
    }
  }
</style>

---
/** Job types map to i18n keys cases.badge.<type> */
const cases = [
  {
    slug: 'barmenforyou',
    display: 'barmenforyou.lt',
    niche: 'HoReCa',
    country: 'LT',
    jobTypes: ['website', 'ads'] as const,
    metrics: [
      { value: '+85%', label: 'Užklausų' },
      { value: 'Stabilus', label: 'Leadų srautas' },
    ],
    tags: ['Landing Page', 'Meta Ads', 'Google Ads'],
  },
  {
    slug: 'skyjet-lt',
    display: 'skyjet.lt',
    niche: 'Private Jets',
    country: 'LT',
    jobTypes: ['ads'] as const,
    metrics: [
      { value: '+120%', label: 'Srauto' },
      { value: '3.1x', label: 'ROAS' },
    ],
    tags: ['Google Ads', 'Meta Ads', 'Retargeting'],
  },
  {
    slug: 'jetshowroom',
    display: 'jetshowroom.com',
    niche: 'Private Jets',
    country: 'GB',
    jobTypes: ['ads'] as const,
    metrics: [
      { value: '+92%', label: 'Konversijų' },
      { value: '2.8x', label: 'ROAS' },
    ],
    tags: ['Meta Ads', 'Google Ads', 'Lead filtravimas'],
  },
  {
    slug: 'inner-lt',
    display: 'inner.lt',
    niche: 'Wellness',
    country: 'LT',
    jobTypes: ['ads'] as const,
    metrics: [
      { value: '+67%', label: 'Reach' },
      { value: '2.2x', label: 'ROI' },
    ],
    tags: ['Meta Ads', 'UGC', 'Retargeting'],
  },
  {
    slug: 'oryzalab',
    display: 'oryzalab.com',
    niche: 'Premium Skincare',
    country: 'FR',
    jobTypes: ['ads'] as const,
    metrics: [
      { value: '+145%', label: 'Srauto' },
      { value: '3.5x', label: 'ROAS' },
    ],
    tags: ['Meta Ads', 'UGC', 'Performance'],
  },
  {
    slug: 'weardzen',
    display: 'weardzen.com',
    niche: 'Fashion',
    country: 'LT',
    jobTypes: ['website', 'ads'] as const,
    metrics: [
      { value: '+110%', label: 'Konversijų' },
      { value: '2.9x', label: 'ROI' },
    ],
    tags: ['UX', 'Google Ads', 'Meta Ads'],
  },
  {
    slug: 'nda',
    display: '',
    niche: '',
    country: null,
    confidential: true,
    jobTypes: ['ai'] as const,
    metrics: [
      { value: '+200%', label: 'Efektyvumas' },
      { value: '-40%', label: 'Laiko' },
    ],
    tags: ['AI', 'Automatizacija', 'Make'],
  },
];

const flagEmoji: Record<string, string> = {
  LT: '\u{1F1F1}\u{1F1F9}',
  GB: '\u{1F1EC}\u{1F1E7}',
  FR: '\u{1F1EB}\u{1F1F7}',
};
---

<section class="cases" id="cases">
  <div class="container">
    <div class="cases__header">
      <div class="cases__header-left" data-animate>
        <span class="cases__num">03 — <span data-i18n="cases.label">Darbai</span></span>
        <h2 class="cases__title" data-i18n="cases.title" data-i18n-br="true">MŪSŲ<br />DARBAI</h2>
      </div>
      <p class="cases__header-desc" data-animate data-animate-delay="1" data-i18n="cases.desc">
        Klientai ir domenai, su kuriais dirbome. Realūs rezultatai, kurie kalba patys už save.
      </p>
    </div>

    <div class="cases__table">
      {
        cases.map((c, idx) => (
          <a href={`/cases/${c.slug}`} class="case-row" data-animate data-animate-delay={String(Math.min(idx + 1, 4))}>
            <div class="case-row__main">
              <div class="case-row__left">
                {c.country && <span class="case-row__flag" title={c.country}>{flagEmoji[c.country] || ''}</span>}
                <span class:list={['case-row__client', { 'case-row__client--nda': c.confidential }]}>
                  {c.confidential ? 'NDA' : c.display}
                </span>
                {!c.confidential && c.niche && <span class="case-row__niche">{c.niche}</span>}
                {c.confidential && <span class="case-row__niche case-row__niche--nda" data-i18n="cases.confidential">Konfidenciali sutartis</span>}
              </div>
              <div class="case-row__job-badges">
                {c.jobTypes.map((t) => (
                  <span class="case-row__job-badge" data-i18n={`cases.badge.${t}`}>
                    {t === 'website' ? 'Svetainė' : t === 'ads' ? 'Reklama' : 'AI / sistema'}
                  </span>
                ))}
              </div>
            </div>
            <div class="case-row__metrics">
              {c.metrics.map((m) => (
                <div class="case-row__metric">
                  <span class="case-row__metric-value">{m.value}</span>
                  <span class="case-row__metric-label">{m.label}</span>
                </div>
              ))}
            </div>
            <div class="case-row__tags">
              {c.tags.map((tag) => (
                <span class="case-row__tag">{tag}</span>
              ))}
            </div>
            <span class="case-row__arrow">→</span>
          </a>
        ))
      }
    </div>
  </div>
</section>

<style>
  .cases {
    padding: 72px 0;
    background: var(--bg);
  }

  .cases__header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 40px;
  }

  .cases__num {
    font-size: 11px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--accent);
    display: block;
    margin-bottom: 16px;
  }

  .cases__title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(48px, 6vw, 96px);
    line-height: 0.9;
    font-weight: 400;
  }

  .cases__header-desc {
    max-width: 320px;
    font-size: 15px;
    color: var(--text-muted);
    line-height: 1.7;
    padding-top: 24px;
  }

  .cases__table {
    border-top: 1px solid var(--border);
  }

  .case-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 14px;
    align-items: start;
    padding: 22px 0;
    border-bottom: 1px solid var(--border);
    text-decoration: none;
    color: inherit;
    transition: background 0.2s, padding-left 0.2s;
    cursor: pointer;
    min-width: 0;
  }

  .case-row:hover {
    background: rgba(200, 247, 58, 0.02);
    padding-left: 10px;
  }

  .case-row__main {
    display: flex;
    flex-direction: column;
    gap: 12px;
    min-width: 0;
  }

  .case-row__left {
    display: flex;
    align-items: baseline;
    gap: 10px;
    min-width: 0;
    flex-wrap: wrap;
  }

  .case-row__flag {
    font-size: 18px;
    line-height: 1;
    flex-shrink: 0;
  }

  .case-row__client {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 22px;
    letter-spacing: 1px;
    word-break: break-word;
  }

  .case-row__client--nda {
    letter-spacing: 4px;
  }

  .case-row__niche {
    font-size: 9px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--accent);
    opacity: 0.75;
  }

  .case-row__niche--nda {
    border: 1px solid rgba(200, 247, 58, 0.25);
    padding: 4px 8px;
    opacity: 1;
  }

  .case-row__job-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    justify-content: flex-start;
  }

  .case-row__job-badge {
    font-size: 9px;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    color: var(--accent);
    background: rgba(200, 247, 58, 0.08);
    border: 1px solid rgba(200, 247, 58, 0.35);
    padding: 5px 10px;
    border-radius: 999px;
    white-space: nowrap;
  }

  .case-row__metrics {
    display: flex;
    gap: 28px;
    flex-wrap: wrap;
  }

  .case-row__metric {
    display: flex;
    align-items: baseline;
    gap: 6px;
  }

  .case-row__metric-value {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 26px;
    color: var(--accent);
    line-height: 1;
  }

  .case-row__metric-label {
    font-size: 8px;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--text-muted);
  }

  .case-row__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    justify-content: flex-end;
  }

  .case-row__tag {
    font-size: 8px;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--text-muted);
    border: 1px solid rgba(255, 255, 255, 0.1);
    padding: 4px 9px;
    transition: border-color 0.3s;
  }

  .case-row:hover .case-row__tag {
    border-color: rgba(200, 247, 58, 0.22);
  }

  .case-row__arrow {
    font-size: 18px;
    color: var(--text-muted);
    transition: color 0.3s, transform 0.3s;
  }

  .case-row:hover .case-row__arrow {
    color: var(--accent);
    transform: translateX(4px);
  }

  @media (min-width: 769px) {
    .case-row {
      grid-template-columns: minmax(0, 1.15fr) 1fr auto 28px;
      gap: 16px 20px;
      align-items: center;
    }

    .case-row__main {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
    }

    .case-row__left {
      flex-wrap: nowrap;
    }

    .case-row__job-badges {
      justify-content: flex-end;
      flex-shrink: 0;
    }
  }

  @media (max-width: 768px) {
    .cases {
      padding: 56px 0;
    }

    .cases__header {
      flex-direction: column;
      gap: 16px;
      margin-bottom: 28px;
    }

    .case-row {
      grid-template-columns: 1fr;
      gap: 12px;
      padding: 20px 0;
    }

    .case-row__arrow {
      display: none;
    }
  }
</style>

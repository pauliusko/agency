---
const cases = [
  {
    slug: 'barmenforyou',
    client: 'BarmenForYou',
    niche: 'HoReCa',
    badge: 'WORDPRESS + ADS',
    metrics: [
      { value: '+85%', label: 'Užklausų' },
      { value: '2.4x', label: 'ROI' },
    ],
    desc: 'WordPress svetainės kūrimas ir reklamos kampanijų paleidimas.',
    tags: ['WordPress', 'Google Ads', 'SEO'],
  },
  {
    slug: 'skyjet-lt',
    client: 'SkyJet.lt',
    niche: 'Kelionės',
    badge: 'META + GOOGLE ADS',
    metrics: [
      { value: '+120%', label: 'Srautas' },
      { value: '3.1x', label: 'ROAS' },
    ],
    desc: 'Kelionių paslaugų reklama per Meta ir Google Ads kanalus.',
    tags: ['Meta Ads', 'Google Ads', 'Analytics'],
  },
  {
    slug: 'jetshowroom',
    client: 'JetShowroom',
    niche: 'Kelionės',
    badge: 'META + GOOGLE ADS',
    metrics: [
      { value: '+92%', label: 'Konversijų' },
      { value: '2.8x', label: 'ROAS' },
    ],
    desc: 'Kelionių paslaugų skaitmeninės reklamos kampanijos per Meta ir Google Ads.',
    tags: ['Meta Ads', 'Google Ads', 'Branding'],
  },
  {
    slug: 'inner-lt',
    client: 'Inner.lt',
    niche: 'Sveikata',
    badge: 'META ADS',
    metrics: [
      { value: '+67%', label: 'Reach' },
      { value: '2.2x', label: 'ROI' },
    ],
    desc: 'Meta Ads kampanijos su tikslia auditorija ir konversijų optimizavimu.',
    tags: ['Meta Ads', 'Targeting', 'Konversijos'],
  },
  {
    slug: 'oryzalab',
    client: 'OryzaLab',
    niche: 'Kosmetika',
    badge: 'ADS + WEBSITE',
    metrics: [
      { value: '+145%', label: 'Srautas' },
      { value: '3.5x', label: 'ROAS' },
    ],
    desc: 'Meta ir Google Ads kampanijos bei svetainės tobulinimas konversijoms.',
    tags: ['Meta Ads', 'Google Ads', 'UX'],
  },
  {
    slug: 'weardzen',
    client: 'WeardZen',
    niche: 'Mada',
    badge: 'REDESIGN + ADS',
    metrics: [
      { value: '+110%', label: 'Konversijų' },
      { value: '2.9x', label: 'ROI' },
    ],
    desc: 'Svetainės redizainas ir reklamos kampanijų paleidimas nuo nulio.',
    tags: ['Web Design', 'Google Ads', 'Meta Ads'],
  },
  {
    slug: 'london-antique',
    client: 'London Antique',
    niche: 'Antikvaras',
    badge: 'CRM SISTEMA',
    metrics: [
      { value: '+200%', label: 'Efektyvumas' },
      { value: '40%', label: 'Laiko taupymas' },
    ],
    desc: 'Individualios CRM sistemos kūrimas verslo procesų automatizavimui.',
    tags: ['CRM', 'Automatizacija', 'UX/UI'],
  },
];
---

<section class="cases" id="cases">
  <div class="container">
    <div class="cases__header">
      <div class="cases__header-left" data-animate>
        <span class="cases__num">03 — <span data-i18n="cases.label">Darbai</span></span>
        <h2 class="cases__title" data-i18n="cases.title">MŪSŲ<br/>DARBAI</h2>
      </div>
      <p class="cases__header-desc" data-animate data-animate-delay="1" data-i18n="cases.desc">
        Klientai, su kuriais dirbome. Realūs rezultatai, kurie kalba patys už save.
      </p>
    </div>

    <div class="cases__table">
      {cases.map((c, idx) => (
        <a href={`/cases/${c.slug}`} class="case-row" data-animate data-animate-delay={String(Math.min(idx + 1, 4))}>
          <div class="case-row__left">
            <span class="case-row__client">{c.client}</span>
            <span class="case-row__niche">{c.niche}</span>
          </div>
          <div class="case-row__metrics">
            {c.metrics.map((m) => (
              <div class="case-row__metric">
                <span class="case-row__metric-value">{m.value}</span>
                <span class="case-row__metric-label">{m.label}</span>
              </div>
            ))}
          </div>
          <div class="case-row__tags">
            {c.tags.map((tag) => (
              <span class="case-row__tag">{tag}</span>
            ))}
          </div>
          <span class="case-row__arrow">→</span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .cases {
    padding: 120px 0;
    background: var(--bg);
  }

  .cases__header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 64px;
  }

  .cases__num {
    font-size: 11px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--accent);
    display: block;
    margin-bottom: 16px;
  }

  .cases__title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(48px, 6vw, 96px);
    line-height: 0.9;
    font-weight: 400;
  }

  .cases__header-desc {
    max-width: 320px;
    font-size: 15px;
    color: var(--text-muted);
    line-height: 1.7;
    padding-top: 24px;
  }

  /* ── Table layout ── */
  .cases__table {
    border-top: 1px solid var(--border);
  }

  .case-row {
    display: grid;
    grid-template-columns: 200px 1fr auto 32px;
    gap: 24px;
    align-items: center;
    padding: 24px 0;
    border-bottom: 1px solid var(--border);
    text-decoration: none;
    color: inherit;
    transition: background 0.2s, padding-left 0.2s;
    cursor: pointer;
  }

  .case-row:hover {
    background: rgba(200, 247, 58, 0.02);
    padding-left: 12px;
  }

  .case-row__left {
    display: flex;
    align-items: baseline;
    gap: 10px;
    min-width: 0;
  }

  .case-row__client {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 22px;
    letter-spacing: 1px;
    white-space: nowrap;
  }

  .case-row__niche {
    font-size: 9px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--accent);
    opacity: 0.6;
    white-space: nowrap;
  }

  .case-row__metrics {
    display: flex;
    gap: 32px;
  }

  .case-row__metric {
    display: flex;
    align-items: baseline;
    gap: 6px;
  }

  .case-row__metric-value {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 28px;
    color: var(--accent);
    line-height: 1;
  }

  .case-row__metric-label {
    font-size: 8px;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--text-muted);
  }

  .case-row__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
    justify-content: flex-end;
  }

  .case-row__tag {
    font-size: 8px;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--text-muted);
    border: 1px solid rgba(255, 255, 255, 0.08);
    padding: 3px 8px;
    transition: border-color 0.3s;
  }

  .case-row:hover .case-row__tag {
    border-color: rgba(200, 247, 58, 0.2);
  }

  .case-row__arrow {
    font-size: 18px;
    color: var(--text-muted);
    transition: color 0.3s, transform 0.3s;
  }

  .case-row:hover .case-row__arrow {
    color: var(--accent);
    transform: translateX(4px);
  }

  @media (max-width: 768px) {
    .cases__header {
      flex-direction: column;
      gap: 16px;
    }

    .case-row {
      grid-template-columns: 1fr;
      gap: 12px;
      padding: 20px 0;
    }

    .case-row__left {
      justify-content: space-between;
    }

    .case-row__metrics {
      gap: 24px;
    }

    .case-row__arrow {
      display: none;
    }
  }
</style>
